APP_KEY=main
PORT=7001
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=admin_platform
JWT_SECRET=CHANGE_ME_LOCAL_JWT

# 缓存：默认 memory（进程内，无需 Redis 容器）
CACHE_DRIVER=memory
CACHE_MENU_TTL=300

# 子应用 entry 覆盖（可选；默认读 subapp_registry.entry_dev）
SUBAPP_NOVEL_ENTRY=http://localhost:5174

# 生产可选 Redis（须 npm install ioredis 且 CACHE_DRIVER=redis）
# CACHE_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Agent 平台（agent-management-master），供 /api/llm/profiles 代理
# 本机 npm run dev 用 127.0.0.1；Docker 栈见 deploy/config/.env.local（host.docker.internal）
AGENT_PLATFORM_URL=http://127.0.0.1:3001
# AGENT_PLATFORM_TIMEOUT=15000
