# Vite 把 /api 代理到此地址（见 vite.config.js）
# 用法：cp frontend/.env.local.example frontend/.env.local
#
# 模式 A — docker compose up（frontend + api-main 同网络，推荐本地全栈）
VITE_PROXY_TARGET=http://api-main:5200
#
# 模式 B — 本机 cd frontend && npm run dev，backend 跑在宿主机 5200
# VITE_PROXY_TARGET=http://localhost:5200

VITE_APP_KEY=main
VITE_DEV_PORT=5100
VITE_SUBAPP_NOVEL_ENTRY=http://localhost:5101

VITE_SUBAPP_TESTGEN_ENTRY=http://localhost:5102
