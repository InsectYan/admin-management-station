# 主应用本地 Docker 默认（可提交 git，密钥放 menu-master/backend/.env）
# 端口注册：docs-project/应用端口与命名注册表.md

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=admin_platform

MAIN_PORT=7001
MAIN_POSTGRES_DB=admin_platform
MAIN_VITE_PORT=5173
MAIN_POSTGRES_PORT=5432

JWT_SECRET=CHANGE_ME_LOCAL_JWT
CACHE_DRIVER=memory

# 主应用加载 novel-sub 微前端 entry（浏览器访问，须与 novel 宿主机端口一致）
SUBAPP_NOVEL_ENTRY=http://localhost:5174

# 国内无法直连 Docker Hub 时使用镜像加速：
POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine