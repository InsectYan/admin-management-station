{
  "name": "ams-novel-cli",
  "version": "1.0.0",
  "private": true,
  "description": "小说子应用本地 Docker CLI（npm link 后使用 ams-novel <命令>）",
  "type": "module",
  "bin": {
    "ams-novel": "./bin/ams-novel.mjs"
  },
  "scripts": {
    "link": "npm link",
    "local": "node scripts/run.mjs local",
    "local:infra": "node scripts/run.mjs local:infra",
    "local:reset": "node scripts/run.mjs local:reset",
    "local:down": "node scripts/run.mjs local:down"
  }
}
