APP_KEY=testgen
TESTGEN_PORT=5202
PORT=5202
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5302
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=testgen_db
AGENT_PLATFORM_URL=http://127.0.0.1:4001
# 与 agent-management-master TESTGEN_INTERNAL_TOKEN 保持一致（Skill 回写 internal API）
INTERNAL_API_TOKEN=
# fitness-agent 仓库根目录（CLI 站测 TS-01；Docker 内默认自动检测 /fitness-agent）
# FITNESS_AGENT_ROOT=e:/AI Tools/projects/fitness-agent
# CLI 执行前自动 npm ci/install（挂载目录缺 node_modules 时）
# FT_CLI_AUTO_INSTALL=false
FT_MAX_CONCURRENT_RUNS=3
FT_CLI_TIMEOUT_MS=600000
MAX_CONCURRENT_JOBS=3
UPLOAD_DIR=/tmp/testgen-uploads
# fitness-judge / sample / explore 默认路径（一般无需改）
# FITNESS_JUDGE_INVOKE_PATH=/api/skills/fitness-judge-skill/invoke
# FITNESS_SAMPLE_INVOKE_PATH=/api/skills/fitness-sample-skill/invoke
# FITNESS_EXPLORE_INVOKE_PATH=/api/skills/fitness-explore-skill/invoke
