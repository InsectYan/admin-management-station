FROM node:22-alpine AS build
WORKDIR /app
COPY agent/package*.json ./agent/
RUN cd agent && npm ci
COPY agent/tsconfig.json ./agent/
COPY agent/src ./agent/src
RUN cd agent && npm run build

FROM node:22-alpine
WORKDIR /app
COPY agent/package*.json ./agent/
RUN cd agent && npm ci --omit=dev
COPY --from=build /app/agent/dist ./agent/dist
COPY workspace-templates ./workspace-templates
RUN mkdir -p workspaces data
WORKDIR /app/agent
EXPOSE 7003
ENV PORT=7003
ENV TEMPLATES_ROOT=/app/workspace-templates
ENV WORKSPACES_ROOT=/app/workspaces
ENV DATA_ROOT=/app/data
CMD ["node", "dist/index.js"]
