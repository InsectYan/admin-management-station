# 本地 Docker 默认（可提交 git，密钥用 CHANGE_ME 或放 apps/*/.env、menu-master/*/.env）
# 端口/库名注册表：docs-project/应用端口与命名注册表.md

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# 主应用 (app_key=main)
MAIN_PORT=7001
MAIN_POSTGRES_DB=admin_platform
MAIN_FRONTEND_PORT=8080
POSTGRES_DB=admin_platform

# 小说子应用 (app_key=novel)
NOVEL_PORT=7002
NOVEL_POSTGRES_DB=novel_db
NOVEL_FRONTEND_PORT=8081

# Agent (app_key=agent)
AGENT_PORT=7003

JWT_SECRET=CHANGE_ME_LOCAL_JWT
