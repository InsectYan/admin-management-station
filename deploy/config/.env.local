# 本地 Docker 默认（可提交 git，密钥用 CHANGE_ME 或放 apps/*/.env、menu-master/*/.env）
# 端口/库名注册表：docs-project/应用端口与命名注册表.md

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# 主应用 (app_key=main)
MAIN_PORT=7001
MAIN_POSTGRES_DB=admin_platform
POSTGRES_DB=admin_platform

# 小说子应用 (app_key=novel)
NOVEL_PORT=7002
NOVEL_POSTGRES_DB=novel_db

# Agent (app_key=agent)
AGENT_PORT=7003

JWT_SECRET=CHANGE_ME_LOCAL_JWT

# Agent Server（Pi v3，对齐 cartoon-agent server/.env）
# LLM 密钥写在 apps/agent-server/.env（gitignore，优先级更高）
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
